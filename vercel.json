{
  "version": 2,
  "buildCommand": "npm run build --prefix frontend && npm run build --prefix backend",
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/src/server.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "backend/src/server.js"
    }
  ]
}
